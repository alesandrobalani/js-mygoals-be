{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "node16",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2020",
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "dist",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node", "jest"]
  },
  "include": ["src/**/*", "test/**/*"]
}
