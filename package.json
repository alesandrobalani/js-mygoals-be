  "description": "Aplicação NestJS para gestão financeira familiar usando Clean Architecture",
  "author": "AI",
  "private": true,
  "scripts": {
    "prestart": "npm run build",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
