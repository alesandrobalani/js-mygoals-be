{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: NestJS App",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--require",
        "ts-node/register"
      ],
      "args": ["${workspaceFolder}/src/main.ts"],
      "cwd": "${workspaceFolder}",
      "sourceMaps": true,
      "smartStep": true,
      "internalConsoleOptions": "openOnSessionStart",
      "env": {
        "NODE_ENV": "development",
        "TS_NODE_PROJECT": "${workspaceFolder}/tsconfig.json"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: NestJS App (PostgreSQL)",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--require",
        "ts-node/register"
      ],
      "args": ["${workspaceFolder}/src/main.ts"],
      "cwd": "${workspaceFolder}",
      "sourceMaps": true,
      "smartStep": true,
      "internalConsoleOptions": "openOnSessionStart",
      "env": {
        "NODE_ENV": "development",
        "TS_NODE_PROJECT": "${workspaceFolder}/tsconfig.json",
        "DB_MODE": "postgres",
        "DB_HOST": "localhost",
        "DB_PORT": "5432",
        "DB_USERNAME": "postgres",
        "DB_PASSWORD": "password",
        "DB_DATABASE": "js_mygoals_be",
        "JWT_SECRET": "dev-secret-change-in-production"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: Testes Unitários",
      "runtimeExecutable": "node",
      "args": [
        "${workspaceFolder}/node_modules/jest/bin/jest.js",
        "--runInBand",
        "--no-coverage",
        "--testPathPattern",
        "${relativeFile}"
      ],
      "cwd": "${workspaceFolder}",
      "sourceMaps": true,
      "smartStep": true,
      "internalConsoleOptions": "openOnSessionStart",
      "env": {
        "JWT_SECRET": "test-secret"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: Todos os Testes",
      "runtimeExecutable": "node",
      "args": [
        "${workspaceFolder}/node_modules/jest/bin/jest.js",
        "--runInBand",
        "--no-coverage"
      ],
      "cwd": "${workspaceFolder}",
      "sourceMaps": true,
      "smartStep": true,
      "internalConsoleOptions": "openOnSessionStart",
      "env": {
        "JWT_SECRET": "test-secret"
      }
    }
  ]
}
